{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "backend.main:app", "--reload"],
      "port": 8000,
      "env": {
        "DATABASE_URL": "postgresql://taxiapp:taxiapp@127.0.0.1:5432/taxiapp"
      }
    },
    {
      "name": "handoff",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8765", "--directory", ".preview/handoff"],
      "port": 8765
    },
    {
      "name": "operator-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3001,
      "cwd": "${workspaceRoot}/operator-web"
    }
  ]
}
