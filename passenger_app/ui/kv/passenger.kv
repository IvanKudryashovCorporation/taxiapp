#:import dp kivy.metrics.dp

<PrimaryButton@Button>:
    size_hint_y: None
    height: dp(50)
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 1, 1, 1, 1
    font_name: app.font_bold
    font_size: "15sp"
    canvas.before:
        Color:
            rgba: 0.03, 0.09, 0.22, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(16)] * 4

<SoftButton@Button>:
    size_hint_y: None
    height: dp(46)
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 0.08, 0.12, 0.22, 1
    font_name: app.font_bold
    font_size: "14sp"
    canvas.before:
        Color:
            rgba: 0.90, 0.93, 0.98, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(14)] * 4

<SegmentButton>:
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    font_name: app.font_bold
    font_size: "14sp"
    color: (1, 1, 1, 1) if self.active else (0.21, 0.28, 0.40, 1)
    canvas.before:
        Color:
            rgba: (0.03, 0.09, 0.22, 1) if self.active else (0.91, 0.94, 0.98, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(16)] * 4

<PanelCard>:
    orientation: "vertical"
    padding: dp(14)
    spacing: dp(8)
    canvas.before:
        Color:
            rgba: self.border_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [self.radius, self.radius, self.radius, self.radius]
        Color:
            rgba: self.bg_color
        RoundedRectangle:
            pos: self.x + 1, self.y + 1
            size: self.width - 2, self.height - 2
            radius: [max(self.radius - 1, 0)] * 4

<TaxiStripe>:
    size_hint: None, None

<PassengerRoot>:
    LoginScreen:
        name: "login"

    VerifyScreen:
        name: "verify"

    MainScreen:
        name: "main"

<LoginScreen>:
    canvas.before:
        Color:
            rgba: 0.94, 0.96, 0.99, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.98, 0.84, 0.23, 0.18
        Rectangle:
            pos: self.x, self.top - dp(180)
            size: self.width, dp(180)

    BoxLayout:
        orientation: "vertical"
        padding: dp(22), dp(24), dp(22), dp(22)
        spacing: dp(14)

        PanelCard:
            size_hint_y: None
            height: dp(410)
            radius: 30
            bg_color: 0.99, 0.995, 1, 1
            border_color: 0.85, 0.89, 0.95, 1

            Label:
                text: "ПАССАЖИРСКОЕ ПРИЛОЖЕНИЕ"
                color: 0.28, 0.36, 0.50, 1
                font_name: app.font_bold
                font_size: "14sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(22)

            Label:
                text: "Профсоюз\n\"Рассвет\""
                color: 0.03, 0.09, 0.22, 1
                font_name: app.font_display
                font_size: "52sp"
                line_height: 0.88
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(170)

            Label:
                text: "Закажите поездку за пару минут: выберите маршрут на карте, рассчитайте стоимость и отслеживайте водителя в реальном времени."
                color: 0.40, 0.48, 0.60, 1
                font_name: app.font_regular
                font_size: "17sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(82)

            Widget:

            AnchorLayout:
                size_hint_y: None
                height: dp(18)
                anchor_x: "left"
                TaxiStripe:
                    size: dp(176), dp(14)

            Label:
                text: "Карта • расчёт • история • чат"
                color: 0.13, 0.20, 0.33, 1
                font_name: app.font_bold
                font_size: "14sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(24)

        PanelCard:
            size_hint_y: None
            height: dp(278)
            radius: 26
            bg_color: 0.99, 0.995, 1, 1
            border_color: 0.85, 0.89, 0.95, 1

            Label:
                text: "Введите номер телефона"
                color: 0.14, 0.22, 0.35, 1
                font_name: app.font_bold
                font_size: "20sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(32)

            Label:
                text: "Мы отправим тестовый SMS-код для входа"
                color: 0.45, 0.53, 0.64, 1
                font_name: app.font_regular
                font_size: "13sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(18)

            TextInput:
                id: phone_input
                hint_text: "+7 999 123-45-67"
                multiline: False
                input_type: "tel"
                font_name: app.font_regular
                font_size: "18sp"
                foreground_color: 0.09, 0.12, 0.20, 1
                hint_text_color: 0.56, 0.62, 0.70, 1
                background_normal: ""
                background_active: ""
                background_color: 1, 1, 1, 1
                cursor_color: 0.16, 0.26, 0.45, 1
                padding: dp(16), dp(16), dp(16), dp(10)
                size_hint_y: None
                height: dp(58)
                canvas.before:
                    Color:
                        rgba: 0.86, 0.89, 0.95, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(18)] * 4
                    Color:
                        rgba: 1, 1, 1, 1
                    RoundedRectangle:
                        pos: self.x + 1, self.y + 1
                        size: self.width - 2, self.height - 2
                        radius: [dp(17)] * 4

            PrimaryButton:
                text: "Получить код"
                on_release: root.submit_phone()

            Label:
                text: root.status_text
                color: 0.36, 0.46, 0.60, 1
                font_name: app.font_regular
                font_size: "12sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(36)

<VerifyScreen>:
    canvas.before:
        Color:
            rgba: 0.94, 0.96, 0.99, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"
        padding: dp(22), dp(28), dp(22), dp(22)
        spacing: dp(14)

        PanelCard:
            size_hint_y: None
            height: dp(300)
            radius: 28
            bg_color: 0.05, 0.11, 0.24, 1
            border_color: 0.09, 0.18, 0.34, 1

            Label:
                text: "ПОДТВЕРЖДЕНИЕ ВХОДА"
                color: 0.84, 0.89, 0.98, 0.92
                font_name: app.font_bold
                font_size: "14sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(22)

            Label:
                text: "Код отправлен на номер"
                color: 0.76, 0.82, 0.92, 1
                font_name: app.font_regular
                font_size: "18sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(30)

            Label:
                text: root.phone_text
                color: 1, 1, 1, 1
                font_name: app.font_display
                font_size: "34sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(72)

            Widget:

            AnchorLayout:
                size_hint_y: None
                height: dp(18)
                anchor_x: "left"
                TaxiStripe:
                    size: dp(176), dp(14)

        PanelCard:
            size_hint_y: None
            height: dp(280)
            radius: 26
            bg_color: 0.99, 0.995, 1, 1
            border_color: 0.85, 0.89, 0.95, 1

            Label:
                text: "Введите SMS-код"
                color: 0.14, 0.22, 0.35, 1
                font_name: app.font_bold
                font_size: "20sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(32)

            TextInput:
                id: code_input
                hint_text: "Например: 1111"
                multiline: False
                input_filter: "int"
                font_name: app.font_regular
                font_size: "20sp"
                foreground_color: 0.09, 0.12, 0.20, 1
                hint_text_color: 0.56, 0.62, 0.70, 1
                background_normal: ""
                background_active: ""
                background_color: 1, 1, 1, 1
                cursor_color: 0.16, 0.26, 0.45, 1
                padding: dp(16), dp(16), dp(16), dp(10)
                size_hint_y: None
                height: dp(58)
                canvas.before:
                    Color:
                        rgba: 0.86, 0.89, 0.95, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(18)] * 4
                    Color:
                        rgba: 1, 1, 1, 1
                    RoundedRectangle:
                        pos: self.x + 1, self.y + 1
                        size: self.width - 2, self.height - 2
                        radius: [dp(17)] * 4

            PrimaryButton:
                text: "Войти"
                on_release: root.submit_code()

            SoftButton:
                text: "Назад"
                on_release: app.root.current = "login"

            Label:
                text: root.status_text
                color: 0.36, 0.46, 0.60, 1
                font_name: app.font_regular
                font_size: "12sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(34)

<MainScreen>:
    FloatLayout:
        canvas.before:
            Color:
                rgba: 0.94, 0.96, 0.99, 1
            Rectangle:
                pos: self.pos
                size: self.size

        PassengerMapPanel:
            id: map_panel
            size_hint: 1, 1

        PanelCard:
            size_hint: None, None
            size: self.parent.width - dp(20), dp(74)
            pos: dp(10), self.parent.height - dp(84)
            radius: 24
            bg_color: 0.99, 0.995, 1, 0.96
            border_color: 0.84, 0.88, 0.94, 1

            BoxLayout:
                orientation: "horizontal"
                spacing: dp(10)

                BoxLayout:
                    orientation: "vertical"
                    spacing: dp(2)

                    Label:
                        text: "ПАССАЖИРСКОЕ ТАКСИ"
                        font_name: app.font_bold
                        color: 0.32, 0.40, 0.54, 1
                        font_size: "11sp"
                        text_size: self.width, None
                        halign: "left"
                        valign: "middle"
                        size_hint_y: None
                        height: dp(16)

                    Label:
                        text: "Профсоюз \"Рассвет\""
                        font_name: app.font_display
                        color: 0.04, 0.10, 0.22, 1
                        font_size: "22sp"
                        text_size: self.width, None
                        halign: "left"
                        valign: "middle"
                        size_hint_y: None
                        height: dp(30)

                Label:
                    text: root.ws_state
                    font_name: app.font_regular
                    color: 0.42, 0.49, 0.61, 1
                    text_size: self.size
                    halign: "right"
                    valign: "middle"

        PanelCard:
            orientation: "vertical"
            size_hint: None, None
            size: self.parent.width - dp(20), dp(420)
            pos: dp(10), dp(10)
            radius: 28
            bg_color: 0.99, 0.995, 1, 0.98
            border_color: 0.84, 0.88, 0.94, 1
            padding: dp(12)
            spacing: dp(10)

            BoxLayout:
                size_hint_y: None
                height: dp(46)
                spacing: dp(8)

                SegmentButton:
                    text: "Заказ"
                    active: root.mode == "create"
                    on_release: root.switch_mode("create")

                SegmentButton:
                    text: "Поездка"
                    active: root.mode == "ride"
                    on_release: root.switch_mode("ride")

                SegmentButton:
                    text: "История"
                    active: root.mode == "history"
                    on_release: root.switch_mode("history")

            ScreenManager:
                id: panel_modes

                Screen:
                    name: "create"

                    ScrollView:
                        do_scroll_x: False
                        bar_width: dp(4)

                        BoxLayout:
                            orientation: "vertical"
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(8)
                            padding: 0, 0, 0, dp(8)

                            Label:
                                text: "Куда поедем?"
                                color: 0.06, 0.11, 0.23, 1
                                font_name: app.font_bold
                                font_size: "18sp"
                                text_size: self.width, None
                                halign: "left"
                                valign: "middle"
                                size_hint_y: None
                                height: dp(28)

                            TextInput:
                                id: pickup_address
                                hint_text: "Откуда"
                                multiline: False
                                font_name: app.font_regular
                                foreground_color: 0.08, 0.12, 0.20, 1
                                hint_text_color: 0.55, 0.60, 0.70, 1
                                background_normal: ""
                                background_active: ""
                                background_color: 0.96, 0.97, 1, 1
                                cursor_color: 0.10, 0.20, 0.36, 1
                                size_hint_y: None
                                height: dp(48)
                                padding: dp(14), dp(14), dp(14), dp(10)

                            TextInput:
                                id: dropoff_address
                                hint_text: "Куда"
                                multiline: False
                                font_name: app.font_regular
                                foreground_color: 0.08, 0.12, 0.20, 1
                                hint_text_color: 0.55, 0.60, 0.70, 1
                                background_normal: ""
                                background_active: ""
                                background_color: 0.96, 0.97, 1, 1
                                cursor_color: 0.10, 0.20, 0.36, 1
                                size_hint_y: None
                                height: dp(48)
                                padding: dp(14), dp(14), dp(14), dp(10)

                            BoxLayout:
                                size_hint_y: None
                                height: dp(44)
                                spacing: dp(8)

                                SoftButton:
                                    text: "Точка А с карты"
                                    on_release: root.use_center_for_pickup()

                                SoftButton:
                                    text: "Точка Б с карты"
                                    on_release: root.use_center_for_dropoff()

                            BoxLayout:
                                size_hint_y: None
                                height: 0
                                opacity: 0
                                disabled: True

                                TextInput:
                                    id: pickup_lat
                                TextInput:
                                    id: pickup_lon
                                TextInput:
                                    id: dropoff_lat
                                TextInput:
                                    id: dropoff_lon

                            BoxLayout:
                                size_hint_y: None
                                height: dp(44)
                                spacing: dp(8)

                                Spinner:
                                    id: car_class
                                    text: "econom"
                                    values: ["econom", "comfort", "business"]
                                    background_normal: ""
                                    background_color: 0.96, 0.97, 1, 1
                                    color: 0.08, 0.12, 0.20, 1

                                Spinner:
                                    id: payment_method
                                    text: "cash"
                                    values: ["cash", "card", "sbp"]
                                    background_normal: ""
                                    background_color: 0.96, 0.97, 1, 1
                                    color: 0.08, 0.12, 0.20, 1

                                TextInput:
                                    id: passengers_count
                                    text: "1"
                                    hint_text: "Пассажиры"
                                    multiline: False
                                    input_filter: "int"
                                    foreground_color: 0.08, 0.12, 0.20, 1
                                    background_normal: ""
                                    background_active: ""
                                    background_color: 0.96, 0.97, 1, 1
                                    cursor_color: 0.10, 0.20, 0.36, 1

                            TextInput:
                                id: promo_code
                                hint_text: "Промокод"
                                multiline: False
                                foreground_color: 0.08, 0.12, 0.20, 1
                                background_normal: ""
                                background_active: ""
                                background_color: 0.96, 0.97, 1, 1
                                cursor_color: 0.10, 0.20, 0.36, 1
                                size_hint_y: None
                                height: dp(42)
                                padding: dp(12), dp(12), dp(12), dp(8)

                            TextInput:
                                id: comment_input
                                hint_text: "Комментарий водителю"
                                multiline: False
                                foreground_color: 0.08, 0.12, 0.20, 1
                                background_normal: ""
                                background_active: ""
                                background_color: 0.96, 0.97, 1, 1
                                cursor_color: 0.10, 0.20, 0.36, 1
                                size_hint_y: None
                                height: dp(42)
                                padding: dp(12), dp(12), dp(12), dp(8)

                            PanelCard:
                                size_hint_y: None
                                height: dp(74)
                                bg_color: 0.05, 0.11, 0.24, 1
                                border_color: 0.05, 0.11, 0.24, 1

                                Label:
                                    text: root.quote_text
                                    font_name: app.font_bold
                                    color: 1, 1, 1, 1
                                    text_size: self.width, None
                                    halign: "left"
                                    valign: "middle"

                            BoxLayout:
                                size_hint_y: None
                                height: dp(50)
                                spacing: dp(8)

                                SoftButton:
                                    text: "Рассчитать"
                                    on_release: root.quote_order()

                                PrimaryButton:
                                    text: "Заказать"
                                    on_release: root.create_order()

                Screen:
                    name: "ride"

                    ScrollView:
                        do_scroll_x: False
                        bar_width: dp(4)

                        BoxLayout:
                            orientation: "vertical"
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(8)
                            padding: 0, 0, 0, dp(8)

                            PanelCard:
                                size_hint_y: None
                                height: dp(148)
                                bg_color: 0.98, 0.99, 1, 1
                                border_color: 0.85, 0.89, 0.95, 1

                                Label:
                                    text: root.ride_text
                                    color: 0.08, 0.12, 0.20, 1
                                    text_size: self.width, None
                                    halign: "left"
                                    valign: "middle"

                            SoftButton:
                                text: "Отменить заказ"
                                on_release: root.cancel_order()

                            Label:
                                text: "Чат с водителем"
                                color: 0.06, 0.11, 0.23, 1
                                font_name: app.font_bold
                                font_size: "16sp"
                                size_hint_y: None
                                height: dp(24)

                            PanelCard:
                                size_hint_y: None
                                height: dp(166)
                                padding: dp(10)
                                bg_color: 0.98, 0.99, 1, 1
                                border_color: 0.85, 0.89, 0.95, 1

                                ScrollView:
                                    do_scroll_x: False
                                    bar_width: dp(4)

                                    GridLayout:
                                        id: chat_box
                                        cols: 1
                                        size_hint_y: None
                                        height: self.minimum_height
                                        spacing: dp(6)

                            BoxLayout:
                                size_hint_y: None
                                height: dp(46)
                                spacing: dp(8)

                                TextInput:
                                    id: chat_input
                                    hint_text: "Сообщение водителю"
                                    multiline: False
                                    font_name: app.font_regular
                                    foreground_color: 0, 0, 0, 1
                                    hint_text_color: 0.56, 0.62, 0.70, 1
                                    background_normal: ""
                                    background_active: ""
                                    background_color: 1, 1, 1, 1
                                    cursor_color: 0, 0, 0, 1
                                    padding: dp(14), dp(12), dp(14), dp(8)
                                    canvas.before:
                                        Color:
                                            rgba: 0.85, 0.89, 0.95, 1
                                        RoundedRectangle:
                                            pos: self.pos
                                            size: self.size
                                            radius: [dp(16)] * 4
                                        Color:
                                            rgba: 1, 1, 1, 1
                                        RoundedRectangle:
                                            pos: self.x + 1, self.y + 1
                                            size: self.width - 2, self.height - 2
                                            radius: [dp(15)] * 4

                                PrimaryButton:
                                    size_hint_x: None
                                    width: dp(120)
                                    text: "Отправить"
                                    on_release: root.send_chat()

                            Label:
                                text: "Оценка после поездки"
                                color: 0.06, 0.11, 0.23, 1
                                font_name: app.font_bold
                                font_size: "16sp"
                                size_hint_y: None
                                height: dp(24)

                            BoxLayout:
                                size_hint_y: None
                                height: dp(42)
                                spacing: dp(6)

                                SoftButton:
                                    text: "1"
                                    on_release: root.submit_feedback(1, feedback_reason.text)
                                SoftButton:
                                    text: "2"
                                    on_release: root.submit_feedback(2, feedback_reason.text)
                                SoftButton:
                                    text: "3"
                                    on_release: root.submit_feedback(3, feedback_reason.text)
                                SoftButton:
                                    text: "4"
                                    on_release: root.submit_feedback(4, feedback_reason.text)
                                SoftButton:
                                    text: "5"
                                    on_release: root.submit_feedback(5, feedback_reason.text)

                            Spinner:
                                id: feedback_reason
                                text: ""
                                values: ["", "rude", "dirty_car", "dangerous_driving", "late", "other"]
                                size_hint_y: None
                                height: dp(42)
                                background_normal: ""
                                background_color: 0.96, 0.97, 1, 1
                                color: 0.08, 0.12, 0.20, 1

                            TextInput:
                                id: feedback_text
                                hint_text: "Комментарий к поездке"
                                multiline: True
                                foreground_color: 0.08, 0.12, 0.20, 1
                                background_normal: ""
                                background_active: ""
                                background_color: 0.96, 0.97, 1, 1
                                cursor_color: 0.10, 0.20, 0.36, 1
                                size_hint_y: None
                                height: dp(78)
                                padding: dp(12), dp(10), dp(12), dp(10)

                Screen:
                    name: "history"

                    ScrollView:
                        do_scroll_x: False
                        bar_width: dp(4)

                        GridLayout:
                            id: history_box
                            cols: 1
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(8)
                            padding: 0, 0, 0, dp(8)

            Label:
                text: root.status_text
                font_name: app.font_regular
                color: 0.34, 0.43, 0.56, 1
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(20)
