#:import dp kivy.metrics.dp
#:import NoTransition kivy.uix.screenmanager.NoTransition

<PrimaryButton@Button>:
    size_hint_y: None
    height: dp(50)
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 1, 1, 1, 1
    font_name: app.font_bold
    font_size: "15sp"
    canvas.before:
        Color:
            rgba: (0.03, 0.09, 0.22, 1) if not self.disabled else (0.55, 0.60, 0.70, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(16)] * 4

<SoftButton@Button>:
    size_hint_y: None
    height: dp(46)
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 0.09, 0.13, 0.24, 1
    font_name: app.font_bold
    font_size: "14sp"
    canvas.before:
        Color:
            rgba: 0.90, 0.93, 0.98, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(14)] * 4

<ChatPanel>:
    orientation: "vertical"
    spacing: dp(10)

    Label:
        text: root.mode_title
        size_hint_y: None
        height: dp(26)
        color: 0.06, 0.11, 0.23, 1
        font_name: app.font_bold
        font_size: "18sp"
        text_size: self.width, None
        halign: "left"
        valign: "middle"

    PanelCard:
        size_hint_y: 1
        padding: dp(10)
        spacing: dp(8)
        radius: 22
        bg_color: 0.98, 0.99, 1, 1
        border_color: 0.85, 0.89, 0.95, 1

        ScrollView:
            id: chat_scroll
            do_scroll_x: False
            bar_width: dp(3)

            BoxLayout:
                id: messages_list
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(8)
                padding: dp(6), dp(6)

    Label:
        text: root.status_text
        size_hint_y: None
        height: dp(20)
        color: 0.40, 0.48, 0.60, 1
        font_name: app.font_regular
        font_size: "12sp"
        text_size: self.width, None
        halign: "left"
        valign: "middle"

    BoxLayout:
        size_hint_y: None
        height: dp(54)
        spacing: dp(8)

        TextInput:
            id: msg_input
            hint_text: "Напишите сообщение"
            multiline: False
            font_name: app.font_regular
            font_size: "15sp"
            foreground_color: 0, 0, 0, 1
            cursor_color: 0, 0, 0, 1
            hint_text_color: 0.58, 0.63, 0.72, 1
            background_normal: ""
            background_active: ""
            background_color: 1, 1, 1, 1
            padding: dp(16), dp(15), dp(16), dp(10)
            on_text_validate: root.send_message()
            canvas.before:
                Color:
                    rgba: 0.85, 0.89, 0.95, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(18)] * 4
                Color:
                    rgba: 1, 1, 1, 1
                RoundedRectangle:
                    pos: self.x + 1, self.y + 1
                    size: self.width - 2, self.height - 2
                    radius: [dp(17)] * 4

        Button:
            size_hint_x: None
            width: dp(50)
            text: "\U0001F44D"
            font_name: app.font_emoji
            font_size: "18sp"
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            color: 0.07, 0.12, 0.22, 1
            on_release: root.add_emoji("\U0001F44D")
            canvas.before:
                Color:
                    rgba: 0.90, 0.93, 0.98, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(18)] * 4

        Button:
            size_hint_x: None
            width: dp(66)
            text: "Отпр."
            font_name: app.font_bold
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_release: root.send_message()
            canvas.before:
                Color:
                    rgba: 0.03, 0.09, 0.22, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(18)] * 4

<PanelCard>:
    orientation: "vertical"
    padding: dp(14)
    spacing: dp(8)
    canvas.before:
        Color:
            rgba: self.border_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [self.radius, self.radius, self.radius, self.radius]
        Color:
            rgba: self.bg_color
        RoundedRectangle:
            pos: self.x + 1, self.y + 1
            size: self.width - 2, self.height - 2
            radius: [max(self.radius - 1, 0)] * 4

<NavButton>:
    markup: True
    font_name: app.font_regular
    font_size: "13sp"
    text_size: self.width - dp(10), self.height - dp(8)
    halign: "center"
    valign: "middle"
    line_height: 1.05
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: (1, 1, 1, 1) if self.active else (0.33, 0.39, 0.51, 1)
    text: self.display_text
    canvas.before:
        Color:
            rgba: (0.03, 0.09, 0.22, 1) if self.active else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(18)] * 4

<TaxiStripe>:
    size_hint: None, None

<LoginScreen>:
    name: "login"
    canvas.before:
        Color:
            rgba: 0.94, 0.96, 0.99, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.98, 0.84, 0.23, 0.20
        Rectangle:
            pos: self.x, self.top - dp(180)
            size: self.width, dp(180)

    BoxLayout:
        orientation: "vertical"
        padding: dp(22), dp(24), dp(22), dp(22)
        spacing: dp(14)

        PanelCard:
            size_hint_y: None
            height: dp(430)
            radius: 30
            bg_color: 0.05, 0.11, 0.24, 1
            border_color: 0.09, 0.18, 0.34, 1

            Label:
                text: "ПРИЛОЖЕНИЕ ДЛЯ ВОДИТЕЛЕЙ"
                color: 0.87, 0.91, 0.99, 0.92
                font_name: app.font_bold
                font_size: "14sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(22)

            Label:
                text: "Профсоюз\n\"Рассвет\""
                color: 1, 1, 1, 1
                font_name: app.font_display
                font_size: "54sp"
                line_height: 0.88
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(180)

            Label:
                text: "Единый вход в рабочее приложение таксиста. Код доступа выдает оператор, поэтому войти может только подтвержденный водитель."
                color: 0.74, 0.80, 0.90, 1
                font_name: app.font_regular
                font_size: "17sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(84)

            Widget:

            AnchorLayout:
                size_hint_y: None
                height: dp(18)
                anchor_x: "left"
                TaxiStripe:
                    size: dp(176), dp(14)

            Label:
                text: "Такси • карта • заказы • чаты"
                color: 0.98, 0.84, 0.23, 1
                font_name: app.font_bold
                font_size: "14sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(24)

        PanelCard:
            size_hint_y: None
            height: dp(282)
            radius: 26
            bg_color: 0.99, 0.995, 1, 1
            border_color: 0.85, 0.89, 0.95, 1

            Label:
                text: "Введите пригласительный код"
                color: 0.14, 0.22, 0.35, 1
                font_name: app.font_bold
                font_size: "20sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(32)

            Label:
                text: "Например: RASSVET-12345"
                color: 0.45, 0.53, 0.64, 1
                font_name: app.font_regular
                font_size: "13sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(18)

            TextInput:
                id: invite_input
                hint_text: "Код, который выдал оператор"
                multiline: False
                font_name: app.font_regular
                font_size: "18sp"
                foreground_color: 0.12, 0.18, 0.28, 1
                hint_text_color: 0.56, 0.62, 0.70, 1
                background_normal: ""
                background_active: ""
                background_color: 1, 1, 1, 1
                cursor_color: 0.14, 0.23, 0.42, 1
                padding: dp(16), dp(16), dp(16), dp(10)
                size_hint_y: None
                height: dp(58)
                on_text_validate: root.submit_code()
                canvas.before:
                    Color:
                        rgba: 0.86, 0.89, 0.95, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(18)] * 4
                    Color:
                        rgba: 1, 1, 1, 1
                    RoundedRectangle:
                        pos: self.x + 1, self.y + 1
                        size: self.width - 2, self.height - 2
                        radius: [dp(17)] * 4

            PrimaryButton:
                text: "Продолжить"
                on_release: root.submit_code()

            Label:
                text: root.status_text
                color: 0.36, 0.46, 0.60, 1
                font_name: app.font_regular
                font_size: "12sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(36)

<DashboardScreen>:
    name: "dashboard"
    canvas.before:
        Color:
            rgba: 0.94, 0.96, 0.99, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"
        padding: dp(8), dp(8), dp(8), dp(8)
        spacing: dp(10)

        PanelCard:
            size_hint_y: None
            height: dp(150)
            radius: 24
            bg_color: 0.05, 0.11, 0.24, 1
            border_color: 0.09, 0.18, 0.34, 1

            BoxLayout:
                orientation: "vertical"
                spacing: dp(10)

                BoxLayout:
                    spacing: dp(12)

                    BoxLayout:
                        orientation: "vertical"
                        spacing: dp(4)

                        Label:
                            text: "ПРОФСОЮЗ \"РАССВЕТ\" • ВОДИТЕЛЬ"
                            color: 0.81, 0.87, 0.96, 0.92
                            font_name: app.font_bold
                            font_size: "12sp"
                            text_size: self.width, None
                            halign: "left"
                            valign: "middle"
                            size_hint_y: None
                            height: dp(20)

                        Label:
                            text: root.driver_name
                            color: 1, 1, 1, 1
                            font_name: app.font_display
                            font_size: "30sp"
                            text_size: self.width, None
                            halign: "left"
                            valign: "middle"
                            size_hint_y: None
                            height: dp(40)

                        Label:
                            text: root.driver_line
                            color: 0.76, 0.82, 0.92, 1
                            font_name: app.font_regular
                            font_size: "13sp"
                            text_size: self.width, None
                            halign: "left"
                            valign: "middle"
                            size_hint_y: None
                            height: dp(22)

                    PanelCard:
                        size_hint_x: None
                        width: dp(150)
                        padding: dp(12)
                        spacing: dp(2)
                        bg_color: 0.98, 0.84, 0.23, 1
                        border_color: 0.98, 0.84, 0.23, 1

                        Label:
                            text: "Баланс"
                            color: 0.13, 0.16, 0.21, 1
                            font_name: app.font_bold
                            font_size: "13sp"
                            text_size: self.width, None
                            halign: "left"
                            valign: "middle"
                            size_hint_y: None
                            height: dp(20)

                        Label:
                            text: root.balance_text
                            color: 0.05, 0.09, 0.16, 1
                            font_name: app.font_display
                            font_size: "26sp"
                            text_size: self.width, None
                            halign: "left"
                            valign: "middle"
                            size_hint_y: None
                            height: dp(34)

                BoxLayout:
                    size_hint_y: None
                    height: dp(38)
                    spacing: dp(10)

                    PanelCard:
                        bg_color: 0.11, 0.18, 0.33, 1
                        border_color: 0.11, 0.18, 0.33, 1
                        padding: dp(12), dp(6)

                        Label:
                            text: root.stats_text
                            color: 0.87, 0.91, 0.98, 1
                            font_name: app.font_regular
                            font_size: "12sp"
                            text_size: self.width, None
                            halign: "left"
                            valign: "middle"

                    PanelCard:
                        size_hint_x: None
                        width: dp(180)
                        orientation: "horizontal"
                        padding: dp(12), dp(4)
                        spacing: dp(8)
                        bg_color: 0.11, 0.18, 0.33, 1
                        border_color: 0.11, 0.18, 0.33, 1

                        Label:
                            text: root.online_label
                            color: 1, 1, 1, 1
                            font_name: app.font_bold
                            font_size: "12sp"
                            text_size: self.size
                            halign: "left"
                            valign: "middle"

                        Switch:
                            active: root.is_online
                            on_active: root.toggle_online(self.active)

                        Label:
                            text: root.ws_state
                            color: 0.77, 0.83, 0.93, 1
                            font_name: app.font_regular
                            font_size: "11sp"
                            text_size: self.size
                            halign: "right"
                            valign: "middle"

        PanelCard:
            size_hint_y: 1
            radius: 24
            bg_color: 0.97, 0.985, 1, 1
            border_color: 0.84, 0.88, 0.94, 1

            BoxLayout:
                orientation: "vertical"
                spacing: dp(10)

                BoxLayout:
                    size_hint_y: None
                    height: dp(44)

                    BoxLayout:
                        orientation: "vertical"
                        spacing: dp(2)

                        Label:
                            text: root.current_title
                            color: 0.06, 0.11, 0.23, 1
                            font_name: app.font_display
                            font_size: "22sp"
                            text_size: self.width, None
                            halign: "left"
                            valign: "middle"
                            size_hint_y: None
                            height: dp(28)

                        Label:
                            text: "Рабочий экран водителя с заказами, картой и связью"
                            color: 0.40, 0.48, 0.60, 1
                            font_name: app.font_regular
                            font_size: "12sp"
                            text_size: self.width, None
                            halign: "left"
                            valign: "middle"
                            size_hint_y: None
                            height: dp(18)

                ScreenManager:
                    id: tab_content
                    transition: NoTransition()

                    Screen:
                        name: "orders"
                        ScrollView:
                            do_scroll_x: False
                            bar_width: dp(4)

                            BoxLayout:
                                orientation: "vertical"
                                size_hint_y: None
                                height: self.minimum_height
                                spacing: dp(10)
                                padding: 0, 0, 0, dp(6)

                                Label:
                                    text: "Текущий заказ"
                                    size_hint_y: None
                                    height: dp(24)
                                    color: 0.06, 0.11, 0.23, 1
                                    font_name: app.font_bold
                                    font_size: "15sp"
                                    text_size: self.width, None
                                    halign: "left"
                                    valign: "middle"

                                BoxLayout:
                                    id: active_order_box
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: self.minimum_height
                                    spacing: dp(8)

                                Label:
                                    text: "Новые предложения"
                                    size_hint_y: None
                                    height: dp(24)
                                    color: 0.06, 0.11, 0.23, 1
                                    font_name: app.font_bold
                                    font_size: "15sp"
                                    text_size: self.width, None
                                    halign: "left"
                                    valign: "middle"

                                BoxLayout:
                                    id: available_orders_box
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: self.minimum_height
                                    spacing: dp(10)

                    Screen:
                        name: "map"
                        FloatLayout:
                            MapPanel:
                                id: map_panel
                                size_hint: 1, 1

                            PanelCard:
                                size_hint: None, None
                                size: self.parent.width - dp(24), dp(96)
                                pos: dp(12), self.parent.height - dp(108)
                                radius: 22
                                bg_color: 0.99, 0.995, 1, 0.97
                                border_color: 0.84, 0.88, 0.94, 1

                                Label:
                                    text: "Карта показывает вас, свободные точки заказов и активный маршрут. Перемещение и позиция обновляются автоматически."
                                    color: 0.12, 0.18, 0.29, 1
                                    font_name: app.font_regular
                                    font_size: "14sp"
                                    text_size: self.width, None
                                    halign: "left"
                                    valign: "middle"

                    Screen:
                        name: "chat"
                        BoxLayout:
                            orientation: "vertical"
                            spacing: dp(10)

                            BoxLayout:
                                size_hint_y: None
                                height: dp(46)
                                spacing: dp(8)

                                PrimaryButton:
                                    text: "Оператор"
                                    on_release: root.show_operator_chat()

                                SoftButton:
                                    text: "Пассажир"
                                    on_release: root.show_passenger_chat()

                            ChatPanel:
                                id: chat_panel

                    Screen:
                        name: "settings"
                        ScrollView:
                            do_scroll_x: False
                            bar_width: dp(4)

                            BoxLayout:
                                orientation: "vertical"
                                size_hint_y: None
                                height: self.minimum_height
                                spacing: dp(10)
                                padding: 0, 0, 0, dp(6)

                                PanelCard:
                                    size_hint_y: None
                                    height: dp(168)
                                    bg_color: 1, 1, 1, 1
                                    border_color: 0.85, 0.89, 0.95, 1

                                    Label:
                                        text: root.driver_name
                                        color: 0.05, 0.10, 0.22, 1
                                        font_name: app.font_display
                                        font_size: "24sp"
                                        text_size: self.width, None
                                        halign: "left"
                                        valign: "middle"
                                        size_hint_y: None
                                        height: dp(32)

                                    Label:
                                        text: root.driver_line
                                        color: 0.38, 0.47, 0.60, 1
                                        font_name: app.font_regular
                                        font_size: "14sp"
                                        text_size: self.width, None
                                        halign: "left"
                                        valign: "middle"
                                        size_hint_y: None
                                        height: dp(24)

                                    Label:
                                        text: "Текущий баланс: " + root.balance_text
                                        color: 0.10, 0.16, 0.27, 1
                                        font_name: app.font_bold
                                        font_size: "15sp"
                                        text_size: self.width, None
                                        halign: "left"
                                        valign: "middle"
                                        size_hint_y: None
                                        height: dp(24)

                                    Label:
                                        text: root.stats_text
                                        color: 0.38, 0.47, 0.60, 1
                                        font_name: app.font_regular
                                        font_size: "13sp"
                                        text_size: self.width, None
                                        halign: "left"
                                        valign: "middle"
                                        size_hint_y: None
                                        height: dp(42)

                                PanelCard:
                                    size_hint_y: None
                                    height: dp(128)
                                    bg_color: 0.99, 0.995, 1, 1
                                    border_color: 0.85, 0.89, 0.95, 1

                                    Label:
                                        text: "Рабочий режим"
                                        color: 0.06, 0.11, 0.23, 1
                                        font_name: app.font_bold
                                        font_size: "16sp"
                                        text_size: self.width, None
                                        halign: "left"
                                        valign: "middle"
                                        size_hint_y: None
                                        height: dp(26)

                                    Label:
                                        text: "Когда переключатель включен, вы получаете новые заказы, отображаетесь оператору и отправляете геопозицию на сервер."
                                        color: 0.38, 0.47, 0.60, 1
                                        font_name: app.font_regular
                                        font_size: "13sp"
                                        text_size: self.width, None
                                        halign: "left"
                                        valign: "middle"

                                PrimaryButton:
                                    text: "Обновить данные"
                                    on_release: root.refresh_data()

        PanelCard:
            size_hint_y: None
            height: dp(88)
            radius: 22
            bg_color: 1, 1, 1, 1
            border_color: 0.84, 0.88, 0.94, 1

            BoxLayout:
                spacing: dp(8)

                NavButton:
                    icon: "\U0001F695"
                    title_text: "заказы"
                    subtitle_text: "лента"
                    active: root.active_tab == "orders"
                    on_release: root.switch_tab("orders")

                NavButton:
                    icon: "\U0001F5FA"
                    title_text: "карта"
                    subtitle_text: "маршрут"
                    active: root.active_tab == "map"
                    on_release: root.switch_tab("map")

                NavButton:
                    icon: "\U0001F4DE"
                    title_text: "связь"
                    subtitle_text: "чаты"
                    active: root.active_tab == "chat"
                    on_release: root.switch_tab("chat")

                NavButton:
                    icon: "\u2699"
                    title_text: "профиль"
                    subtitle_text: "доход"
                    active: root.active_tab == "settings"
                    on_release: root.switch_tab("settings")

<DriverRoot>:
    transition: NoTransition()
    LoginScreen:
    DashboardScreen:
