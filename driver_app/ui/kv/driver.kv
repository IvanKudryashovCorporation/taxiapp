#:import dp kivy.metrics.dp
#:import NoTransition kivy.uix.screenmanager.NoTransition

<ChatPanel>:
    orientation: "vertical"

    canvas.before:
        Color:
            rgba: 0.93, 0.95, 0.98, 1
        Rectangle:
            pos: self.pos
            size: self.size

    ScrollView:
        id: chat_scroll
        do_scroll_x: False
        bar_width: dp(3)
        bar_color: 0.75, 0.81, 0.90, 1
        bar_inactive_color: 0.75, 0.81, 0.90, 0.4

        BoxLayout:
            id: messages_list
            orientation: "vertical"
            size_hint_y: None
            height: self.minimum_height
            padding: dp(12), dp(10)
            spacing: dp(6)

    Widget:
        size_hint_y: None
        height: dp(1)
        canvas:
            Color:
                rgba: 0.86, 0.89, 0.94, 1
            Rectangle:
                pos: self.pos
                size: self.size

    Label:
        text: root.status_text
        color: 0.43, 0.51, 0.63, 1
        font_name: app.font_regular
        font_size: "12sp"
        text_size: self.width - dp(20), None
        halign: "left"
        valign: "middle"
        size_hint_y: None
        height: dp(22)
        padding: dp(10), 0

    BoxLayout:
        orientation: "horizontal"
        size_hint_y: None
        height: dp(72)
        padding: dp(10), dp(10)
        spacing: dp(8)
        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        TextInput:
            id: msg_input
            hint_text: "Сообщение..."
            multiline: False
            input_type: "text"
            font_name: "Roboto"
            font_size: "15sp"
            foreground_color: 0.10, 0.18, 0.32, 1
            hint_text_color: 0.60, 0.67, 0.76, 1
            background_normal: ""
            background_active: ""
            background_color: 0, 0, 0, 0
            cursor_color: 0.10, 0.18, 0.32, 1
            padding: dp(14), dp(13)
            size_hint_y: None
            height: dp(48)
            write_tab: False
            use_bubble: True
            on_text_validate: root.send_message()
            canvas.before:
                Color:
                    rgba: 0.86, 0.89, 0.94, 1
                RoundedRectangle:
                    pos: self.x - 1, self.y - 1
                    size: self.width + 2, self.height + 2
                    radius: [dp(14)]
                Color:
                    rgba: 0.95, 0.97, 1, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]

        Button:
            size_hint: None, None
            size: dp(42), dp(48)
            text: "\U0001F44D"
            font_name: "Roboto"
            font_size: "18sp"
            color: 0.10, 0.18, 0.32, 1
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            on_release: root.add_emoji("\U0001F44D")
            canvas.before:
                Color:
                    rgba: 0.89, 0.93, 0.99, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(12)]

        Button:
            size_hint: None, None
            size: dp(42), dp(48)
            text: "\U0001F695"
            font_name: "Roboto"
            font_size: "18sp"
            color: 0.10, 0.18, 0.32, 1
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            on_release: root.add_emoji("\U0001F695")
            canvas.before:
                Color:
                    rgba: 0.89, 0.93, 0.99, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(12)]

        Button:
            size_hint: None, None
            size: dp(56), dp(48)
            text: "\u27A4"
            font_name: app.font_bold
            font_size: "20sp"
            color: 1, 1, 1, 1
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            on_release: root.send_message()
            canvas.before:
                Color:
                    rgba: 0.03, 0.09, 0.22, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]

<PanelCard>:
    orientation: "vertical"
    padding: dp(12)
    spacing: dp(8)
    canvas.before:
        Color:
            rgba: self.border_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [self.radius, self.radius, self.radius, self.radius]
        Color:
            rgba: self.bg_color
        RoundedRectangle:
            pos: self.x + 1, self.y + 1
            size: (self.width - 2 if self.width > 2 else self.width), (self.height - 2 if self.height > 2 else self.height)
            radius: [max(self.radius - 1, 0), max(self.radius - 1, 0), max(self.radius - 1, 0), max(self.radius - 1, 0)]

<NavButton>:
    markup: True
    font_name: app.font_regular
    text_size: self.width - dp(8), self.height - dp(4)
    halign: "center"
    valign: "middle"
    line_height: 1.05
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: (1, 1, 1, 1) if self.active else (0.28, 0.35, 0.48, 1)
    text: self.display_text
    canvas.before:
        Color:
            rgba: (0.03, 0.09, 0.22, 1) if self.active else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12), dp(12), dp(12), dp(12)]
    canvas.after:
        Color:
            rgba: (0.16, 0.27, 0.48, 0.35) if self.active else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.x + dp(0.8), self.y + dp(0.8)
            size: self.width - dp(1.6), self.height - dp(1.6)
            radius: [dp(12), dp(12), dp(12), dp(12)]

<PriceBubble>:
    size_hint: None, None
    size: dp(72), dp(34)
    color: 1, 1, 1, 1
    font_name: app.font_bold
    font_size: "14sp"
    text_size: self.size
    halign: "center"
    valign: "middle"
    canvas.before:
        Color:
            rgba: 0.03, 0.09, 0.22, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(14), dp(14), dp(14), dp(14)]

<TaxiStripe>:
    size_hint: None, None

<OrderTile>:
    size_hint_y: None
    height: dp(108)
    radius: 14
    bg_color: 1, 1, 1, 1
    border_color: 0.87, 0.90, 0.95, 1
    padding: dp(10), dp(8)
    spacing: dp(6)

    BoxLayout:
        size_hint_y: None
        height: dp(22)

        Label:
            text: root.status_text
            size_hint_x: None
            width: dp(84)
            font_name: app.font_regular
            font_size: "12sp"
            color: 0.40, 0.47, 0.63, 1
            text_size: self.size
            halign: "center"
            valign: "middle"
            canvas.before:
                Color:
                    rgba: (0.89, 0.93, 1, 1) if root.active_order else (0.93, 0.95, 0.99, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(11), dp(11), dp(11), dp(11)]

        Widget:

        Label:
            text: root.price_text
            size_hint_x: None
            width: dp(84)
            font_name: app.font_bold
            font_size: "17sp"
            color: 0.04, 0.10, 0.22, 1
            text_size: self.size
            halign: "right"
            valign: "middle"

    Label:
        text: "[color=#f01986]•[/color]  " + root.route_text
        markup: True
        font_name: app.font_regular
        font_size: "14sp"
        color: 0.34, 0.41, 0.54, 1
        text_size: self.width, None
        halign: "left"
        valign: "middle"
        size_hint_y: None
        height: dp(28)

    Label:
        text: root.client_text
        font_name: app.font_regular
        font_size: "14sp"
        color: 0.34, 0.41, 0.54, 1
        text_size: self.width, None
        halign: "left"
        valign: "middle"
        size_hint_y: None
        height: dp(24)

<LoginScreen>:
    name: "login"
    status_text: ""

    canvas.before:
        Color:
            rgba: 0.93, 0.95, 0.98, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"
        padding: dp(30), dp(34), dp(30), dp(24)
        spacing: dp(14)

        Label:
            text: "РЎ Р• Р  Р’ Р РЎ   Р” Р› РЇ   Р’ Рћ Р” Р Рў Р• Р› Р• Р™"
            color: 0.25, 0.34, 0.50, 1
            font_name: app.font_bold
            font_size: "21sp"
            text_size: self.width, None
            halign: "center"
            valign: "middle"
            size_hint_y: None
            height: dp(38)

        Label:
            text: 'ПРОФСОЮЗ\n"РАССВЕТ"'
            color: 0.03, 0.10, 0.24, 1
            font_name: app.font_bold
            font_size: "58sp"
            line_height: 0.9
            text_size: self.width, None
            halign: "center"
            valign: "middle"
            size_hint_y: None
            height: dp(188)

        Label:
            text: "Единый вход в рабочее приложение таксиста"
            color: 0.43, 0.51, 0.63, 1
            font_name: app.font_regular
            font_size: "18sp"
            text_size: self.width, None
            halign: "center"
            valign: "middle"
            size_hint_y: None
            height: dp(62)

        AnchorLayout:
            size_hint_y: None
            height: dp(22)
            anchor_x: "center"
            anchor_y: "center"
            TaxiStripe:
                size: dp(182), dp(14)

        Widget:
            size_hint_y: 1

        PanelCard:
            size_hint_y: None
            height: dp(246)
            radius: 20
            bg_color: 0.985, 0.99, 1, 1
            border_color: 0.86, 0.89, 0.94, 1
            padding: dp(18)
            spacing: dp(12)

            Label:
                text: "Введите свой пригласительный код"
                color: 0.19, 0.27, 0.40, 1
                font_name: app.font_bold
                font_size: "17sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(32)

            TextInput:
                id: invite_input
                hint_text: "Например: RASSVET-12345"
                multiline: False
                input_type: "text"
                font_name: app.font_regular
                font_size: "14sp"
                foreground_color: 0.20, 0.29, 0.41, 1
                hint_text_color: 0.56, 0.62, 0.70, 1
                background_normal: ""
                background_active: ""
                background_color: 0.97, 0.98, 1, 1
                cursor_color: 0.16, 0.26, 0.45, 1
                padding: dp(14), dp(17), dp(14), dp(10)
                size_hint_y: None
                height: dp(54)

            Button:
                text: "Продолжить"
                size_hint_y: None
                height: dp(56)
                background_normal: ""
                background_down: ""
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1
                font_name: app.font_bold
                font_size: "18sp"
                on_release: root.submit_code()
                canvas.before:
                    Color:
                        rgba: 0.03, 0.09, 0.22, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(14), dp(14), dp(14), dp(14)]

            Label:
                text: root.status_text
                color: 0.36, 0.46, 0.60, 1
                font_name: app.font_regular
                font_size: "12sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(34)

<DashboardScreen>:
    name: "dashboard"

    canvas.before:
        Color:
            rgba: 0.93, 0.95, 0.98, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"
        padding: dp(6), dp(8), dp(6), dp(8)
        spacing: dp(8)

        PanelCard:
            size_hint_y: None
            height: dp(64)
            radius: 15
            bg_color: 1, 1, 1, 1
            border_color: 0.86, 0.89, 0.94, 1

            BoxLayout:
                orientation: "horizontal"
                Label:
                    text: "заработано:"
                    color: 0.04, 0.10, 0.22, 1
                    font_name: app.font_bold
                    font_size: "18sp"
                    text_size: self.size
                    halign: "left"
                    valign: "middle"
                Label:
                    text: root.earned_text
                    color: 0.04, 0.10, 0.22, 1
                    font_name: app.font_bold
                    font_size: "18sp"
                    text_size: self.size
                    halign: "right"
                    valign: "middle"

        PanelCard:
            size_hint_y: 1
            radius: 16
            bg_color: 0.96, 0.97, 0.99, 1
            border_color: 0.83, 0.87, 0.93, 1
            padding: dp(12)
            spacing: dp(8)

            Label:
                text: root.current_title
                color: 0.04, 0.10, 0.22, 1
                font_name: app.font_bold
                font_size: "17sp"
                text_size: self.width, None
                halign: "left"
                valign: "middle"
                size_hint_y: None
                height: dp(30)

            ScreenManager:
                id: tab_content
                transition: NoTransition()

                Screen:
                    name: "orders"
                    BoxLayout:
                        orientation: "vertical"
                        spacing: dp(10)

                        OrderTile:
                            active_order: True
                            status_text: "Активный"
                            route_text: "Тверская 12 → Ленинградский вокзал"
                            client_text: "Клиент: +7 (916) 555-24-81"
                            price_text: "790 ₽"

                        OrderTile:
                            active_order: False
                            status_text: "Ожидает"
                            route_text: "Проспект Мира 45 → Шереметьево D"
                            client_text: "Клиент: +7 (985) 713-09-44"
                            price_text: "1 120 ₽"

                        OrderTile:
                            active_order: False
                            status_text: "Ожидает"
                            route_text: "Кутузовский 21 → Киевский вокзал"
                            client_text: "Клиент: +7 (903) 777-16-53"
                            price_text: "640 ₽"

                        Widget:

                Screen:
                    name: "map"
                    MapPanel:
                        id: map_panel

                Screen:
                    name: "chat"
                    ScreenManager:
                        id: chat_nav
                        transition: NoTransition()

                        Screen:
                            name: "contacts"
                            BoxLayout:
                                orientation: "vertical"
                                spacing: dp(12)
                                padding: dp(4), dp(4)
                                Button:
                                    size_hint_y: None
                                    height: dp(80)
                                    markup: True
                                    text: "[font=Roboto][size=24]\U0001F4DE[/size]  [b]Оператор[/b]\n[size=13]Чат с администратором[/size][/font]"
                                    font_name: "Roboto"
                                    text_size: self.width - dp(24), self.height
                                    halign: "left"
                                    valign: "middle"
                                    color: 0.06, 0.12, 0.24, 1
                                    padding: dp(14), 0
                                    background_normal: ""
                                    background_down: ""
                                    background_color: 0, 0, 0, 0
                                    on_release: root.open_chat("operator")
                                    canvas.before:
                                        Color:
                                            rgba: 0.86, 0.89, 0.94, 1
                                        RoundedRectangle:
                                            pos: self.pos
                                            size: self.size
                                            radius: [dp(14)]
                                        Color:
                                            rgba: 1, 1, 1, 1
                                        RoundedRectangle:
                                            pos: self.x + 1, self.y + 1
                                            size: self.width - 2, self.height - 2
                                            radius: [dp(13)]

                                Widget:

                        Screen:
                            name: "conversation"
                            BoxLayout:
                                orientation: "vertical"

                                BoxLayout:
                                    size_hint_y: None
                                    height: dp(44)
                                    padding: dp(4), dp(6)
                                    spacing: dp(8)
                                    canvas.before:
                                        Color:
                                            rgba: 1, 1, 1, 1
                                        Rectangle:
                                            pos: self.pos
                                            size: self.size

                                    Button:
                                        size_hint_x: None
                                        width: dp(80)
                                        text: "< Назад"
                                        font_name: app.font_bold
                                        font_size: "14sp"
                                        color: 0.04, 0.10, 0.22, 1
                                        background_normal: ""
                                        background_down: ""
                                        background_color: 0, 0, 0, 0
                                        size_hint_y: None
                                        height: dp(32)
                                        pos_hint: {"center_y": 0.5}
                                        on_release: root.close_chat()

                                    Label:
                                        text: "Оператор"
                                        font_name: app.font_bold
                                        font_size: "16sp"
                                        color: 0.04, 0.10, 0.22, 1
                                        text_size: self.size
                                        halign: "left"
                                        valign: "middle"

                                ChatPanel:
                                    id: chat_panel

                Screen:
                    name: "settings"
                    BoxLayout:
                        orientation: "vertical"
                        spacing: dp(10)

                        Label:
                            text: "Настройки"
                            font_name: app.font_bold
                            font_size: "17sp"
                            color: 0.04, 0.10, 0.22, 1
                            text_size: self.size
                            halign: "left"
                            valign: "middle"
                            size_hint_y: None
                            height: dp(26)

                        PanelCard:
                            size_hint_y: None
                            height: dp(210)
                            radius: 18
                            bg_color: 0.98, 0.99, 1, 1
                            border_color: 0.86, 0.89, 0.94, 1
                            padding: dp(16), dp(14)
                            spacing: dp(8)

                            Label:
                                text: "РРІР°РЅ РџРµС‚СЂРѕРІ"
                                font_name: app.font_bold
                                font_size: "28sp"
                                color: 0.04, 0.10, 0.22, 1
                                text_size: self.width, None
                                halign: "left"
                                valign: "middle"
                                size_hint_y: None
                                height: dp(36)

                            Label:
                                text: root.driver_line
                                font_name: app.font_regular
                                font_size: "14sp"
                                color: 0.40, 0.52, 0.66, 1
                                text_size: self.width, None
                                halign: "left"
                                valign: "middle"
                                size_hint_y: None
                                height: dp(24)

                            BoxLayout:
                                size_hint_y: None
                                height: dp(34)
                                Label:
                                    text: "Принимать заказы автоматически"
                                    font_name: app.font_regular
                                    font_size: "15sp"
                                    color: 0.20, 0.29, 0.41, 1
                                    text_size: self.size
                                    halign: "left"
                                    valign: "middle"
                                CheckBox:
                                    active: True
                                    size_hint_x: None
                                    width: dp(42)

                            BoxLayout:
                                size_hint_y: None
                                height: dp(34)
                                Label:
                                    text: "Ночной режим заказов"
                                    font_name: app.font_regular
                                    font_size: "15sp"
                                    color: 0.20, 0.29, 0.41, 1
                                    text_size: self.size
                                    halign: "left"
                                    valign: "middle"
                                CheckBox:
                                    active: True
                                    size_hint_x: None
                                    width: dp(42)

                            BoxLayout:
                                size_hint_y: None
                                height: dp(34)
                                Label:
                                    text: "Голосовые уведомления"
                                    font_name: app.font_regular
                                    font_size: "15sp"
                                    color: 0.20, 0.29, 0.41, 1
                                    text_size: self.size
                                    halign: "left"
                                    valign: "middle"
                                CheckBox:
                                    active: True
                                    size_hint_x: None
                                    width: dp(42)

                        Widget:

        PanelCard:
            size_hint_y: None
            height: dp(84)
            radius: 16
            bg_color: 1, 1, 1, 1
            border_color: 0.84, 0.88, 0.94, 1
            padding: dp(10), dp(8)

            BoxLayout:
                spacing: dp(8)

                NavButton:
                    icon: "\U0001F695"
                    title_text: "в заказе"
                    subtitle_text: "активные"
                    active: root.active_tab == "orders"
                    on_release: root.switch_tab("orders")

                NavButton:
                    icon: "\U0001F5FA"
                    title_text: "карта"
                    subtitle_text: "gps"
                    active: root.active_tab == "map"
                    on_release: root.switch_tab("map")

                NavButton:
                    icon: "\U0001F4DE"
                    title_text: "связь"
                    subtitle_text: "чаты"
                    active: root.active_tab == "chat"
                    on_release: root.switch_tab("chat")

                NavButton:
                    icon: "\u2699"
                    title_text: "настройки"
                    subtitle_text: "профиль"
                    active: root.active_tab == "settings"
                    on_release: root.switch_tab("settings")

<DriverRoot>:
    transition: NoTransition()
    LoginScreen:
    DashboardScreen:



